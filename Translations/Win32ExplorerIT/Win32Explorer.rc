        MENUITEM "Deselezione con carattere jolly...",       IDM_EDIT_WILDCARDDESELECT
    END
    POPUP "&Vista"
    BEGIN
        MENUITEM "Doppio pannello",                  IDM_VIEW_DUAL_PANE
        MENUITEM "Barra di &stato",                 IDM_VIEW_STATUSBAR
        MENUITEM "Car&telle",                    IDM_VIEW_FOLDERS
        MENUITEM "Vetri&na",             IDM_VIEW_DISPLAYWINDOW
        POPUP "&Barre strumenti"
        BEGIN
            MENUITEM "&Barra degli indirizzi",                IDM_VIEW_TOOLBARS_ADDRESS_BAR
            MENUITEM "&Barra Principale",               IDM_VIEW_TOOLBARS_MAIN_TOOLBAR
            MENUITEM "&Segnalibri",                  IDM_VIEW_TOOLBARS_BOOKMARKS_TOOLBAR
            MENUITEM "&Unità disco",                     IDM_VIEW_TOOLBARS_DRIVES_TOOLBAR
            MENUITEM "Barra &Strumenti Dell'Applicazione",        IDM_VIEW_TOOLBARS_APPLICATION_TOOLBAR
            MENUITEM SEPARATOR
            MENUITEM "&Blocca Barre Strumenti",              IDM_VIEW_TOOLBARS_LOCK_TOOLBARS
            MENUITEM "&Personalizza...",               IDM_VIEW_TOOLBARS_CUSTOMIZE
        END
        MENUITEM SEPARATOR
        MENUITEM "Diminuisci dimensione testo",          IDM_VIEW_DECREASE_TEXT_SIZE
        MENUITEM "Aumenta dimensione testo",          IDM_VIEW_INCREASE_TEXT_SIZE
        MENUITEM SEPARATOR
        MENUITEM "Placeholder",                 IDM_VIEW_PLACEHOLDER
        MENUITEM SEPARATOR
        MENUITEM "Disposizione &automatica",               IDM_VIEW_AUTOARRANGE
        MENUITEM SEPARATOR
        MENUITEM "&Ordina per",                    IDM_VIEW_SORTBY
        MENUITEM "Ra&ggruppa per",                   IDM_VIEW_GROUPBY
        MENUITEM "Visualizza file &nascosti",          IDM_VIEW_SHOWHIDDENFILES
        MENUITEM "&Refresh",                    IDM_VIEW_REFRESH
        MENUITEM "Seleziona &colonne...",          IDM_VIEW_SELECTCOLUMNS
        MENUITEM "Ri&dimensiona automaticamente colonne",           IDM_VIEW_AUTOSIZECOLUMNS
        MENUITEM "Sal&va disposizione colonne come predefinita", IDM_VIEW_SAVECOLUMNLAYOUTASDEFAULT
        MENUITEM "Cambia colo&ri della vetrina...", IDM_VIEW_CHANGEDISPLAYCOLOURS
        MENUITEM SEPARATOR
        POPUP "&Filtro"
        BEGIN
            MENUITEM "&Imposta Filtro...",              IDM_FILTER_FILTERRESULTS
            MENUITEM "Abilita filtro",              IDM_FILTER_ENABLE_FILTER
        END
    END
    POPUP "&Azioni"
    BEGIN
        MENUITEM "Nuova &cartella",                 IDM_ACTIONS_NEWFOLDER
        MENUITEM SEPARATOR
        MENUITEM "&Dividi file...",              IDM_ACTIONS_SPLITFILE
        MENUITEM "&Unisci i file...",             IDM_ACTIONS_MERGEFILES
        MENUITEM "&Distruggi file...",         IDM_ACTIONS_DESTROYFILES
    END
    POPUP "&Vai"
    BEGIN
        MENUITEM "&Indietro",                       IDM_GO_BACK
        MENUITEM "&Avanti",                    IDM_GO_FORWARD
        MENUITEM "&Su",                         IDM_GO_UP
        MENUITEM SEPARATOR
        MENUITEM "&Cronologia",                    IDM_GO_HISTORY
        MENUITEM "Posizioni &frequenti",         IDM_GO_FREQUENT_LOCATIONS
    END
    MENUITEM "&Segnalibri",                  IDM_BOOKMARKS
    POPUP "S&trumenti"
    BEGIN
        MENUITEM "&Cerca...",                  IDM_TOOLS_SEARCH
        MENUITEM "&Personalizza colori...",        IDM_TOOLS_CUSTOMIZECOLORS
        MENUITEM SEPARATOR
        MENUITEM "Esegui script...",               IDM_TOOLS_RUNSCRIPT
        MENUITEM "&Opzioni...",                 IDM_TOOLS_OPTIONS
    END
    POPUP "&Finestra"
    BEGIN
        MENUITEM "&Cerca schede...",             IDM_WINDOW_SEARCH_TABS
    END
    POPUP "&Aiuto"
    BEGIN
        MENUITEM "Documentazione Online",       IDM_HELP_ONLINE_DOCUMENTATION
        MENUITEM SEPARATOR
        MENUITEM "Verifica la presenza di aggiornamenti...",        IDM_HELP_CHECKFORUPDATES
        MENUITEM "&Informazioni su Win32Explorer",           IDM_HELP_ABOUT
    END
END

