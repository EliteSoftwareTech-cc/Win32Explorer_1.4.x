IDR_MAINMENU MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Nuova Scheda",                    IDM_FILE_NEWTAB
        MENUITEM "&Chiudi Scheda",                  IDM_FILE_CLOSETAB
        MENUITEM "Nuova F&inestra",                 IDM_FILE_NEW_WINDOW
        MENUITEM "&Riapri scheda recente",          IDM_FILE_REOPEN_RECENT_TAB
        MENUITEM "Clona &finestra",               IDM_FILE_CLONEWINDOW
        MENUITEM SEPARATOR
        MENUITEM "&Salva elenco directory...",  IDM_FILE_SAVEDIRECTORYLISTING
        MENUITEM "&Apri prompt dei comandi",        IDM_FILE_OPENCOMMANDPROMPT
        MENUITEM "Apri prompt dei comandi come &Amministratore", IDM_FILE_OPENCOMMANDPROMPTADMINISTRATOR
        MENUITEM "Copia &Percorso della Cartella",           IDM_FILE_COPYFOLDERPATH
        MENUITEM "Copia percorsi fi&le",            IDM_FILE_COPYITEMPATH
        MENUITEM "Copia percorsi &universali file",  IDM_FILE_COPYUNIVERSALFILEPATHS
        MENUITEM "Copia &testo colonna",           IDM_FILE_COPYCOLUMNTEXT
        MENUITEM SEPARATOR
        MENUITEM "Imposta &attributi file...",     IDM_FILE_SETFILEATTRIBUTES
        MENUITEM "&Elimina",                     IDM_FILE_DELETE
        MENUITEM "Elimina definitivamente",         IDM_FILE_DELETEPERMANENTLY
        MENUITEM "Rino&mina",                     IDM_FILE_RENAME
        MENUITEM "P&roprietà",                 IDM_FILE_PROPERTIES
        MENUITEM SEPARATOR
        MENUITEM "&Esci",                       IDM_FILE_EXIT
    END
    POPUP "&Modifica"
    BEGIN
        MENUITEM "&Annulla",                       IDM_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "&Taglia",                        IDM_EDIT_CUT
        MENUITEM "&Copia",                       IDM_EDIT_COPY
        MENUITEM "&Incolla",                      IDM_EDIT_PASTE
        MENUITEM "Incolla collegamento",             IDM_EDIT_PASTESHORTCUT
        MENUITEM "Incolla coll&egamento fisico",            IDM_EDIT_PASTEHARDLINK
        MENUITEM "Incolla Link S&imbolico",        IDM_EDIT_PASTE_SYMBOLIC_LINK
        MENUITEM SEPARATOR
        MENUITEM "Copia Nella &Cartella",             IDM_EDIT_COPYTOFOLDER
        MENUITEM "Sposta nella Cartella",             IDM_EDIT_MOVETOFOLDER
        MENUITEM SEPARATOR
        MENUITEM "&Risolvi collegamento",               IDM_EDIT_RESOLVELINK
    END
    POPUP "&Selezione"
    BEGIN
        MENUITEM "Seleziona &tutto",                 IDM_EDIT_SELECTALL
        MENUITEM "&Inverti selezione",           IDM_EDIT_INVERTSELECTION
        MENUITEM "Seleziona tutti dello stessa &tipologia",    IDM_EDIT_SELECTALLOFSAMETYPE
        MENUITEM "&Nessuna selezione",                IDM_EDIT_SELECTNONE
