IDR_MAINMENU MENU
BEGIN
    POPUP "&Файл"
    BEGIN
        MENUITEM "&New Tab",                    IDM_FILE_NEWTAB
        MENUITEM "&Close Tab",                  IDM_FILE_CLOSETAB
        MENUITEM "New W&indow",                 IDM_FILE_NEW_WINDOW
        MENUITEM "&Reopen Recent Tab",          IDM_FILE_REOPEN_RECENT_TAB
        MENUITEM "&Клонувати Вікно",               IDM_FILE_CLONEWINDOW
        MENUITEM SEPARATOR
        MENUITEM "Зберегти С&труктуру Тек...",  IDM_FILE_SAVEDIRECTORYLISTING
        MENUITEM "&Open Command Prompt",        IDM_FILE_OPENCOMMANDPROMPT
        MENUITEM "Open Command Prompt as &Administrator", IDM_FILE_OPENCOMMANDPROMPTADMINISTRATOR
        MENUITEM "Copy &Folder Path",           IDM_FILE_COPYFOLDERPATH
        MENUITEM "Копіювати Шляхи до &Файлів",            IDM_FILE_COPYITEMPATH
        MENUITEM "Копіювати &Універсальні шляхи до Файлу",  IDM_FILE_COPYUNIVERSALFILEPATHS
        MENUITEM "Копіювати &Текст Колонки",           IDM_FILE_COPYCOLUMNTEXT
        MENUITEM SEPARATOR
        MENUITEM "Задати &Атрибути Файлів...",     IDM_FILE_SETFILEATTRIBUTES
        MENUITEM "&Delete",                     IDM_FILE_DELETE
        MENUITEM "Delete &Permanently",         IDM_FILE_DELETEPERMANENTLY
        MENUITEM "Rena&me",                     IDM_FILE_RENAME
        MENUITEM "P&roperties",                 IDM_FILE_PROPERTIES
        MENUITEM SEPARATOR
        MENUITEM "Ви&хід",                       IDM_FILE_EXIT
    END
    POPUP "Реда&гувати"
    BEGIN
        MENUITEM "&Undo",                       IDM_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t",                        IDM_EDIT_CUT
        MENUITEM "&Copy",                       IDM_EDIT_COPY
        MENUITEM "&Paste",                      IDM_EDIT_PASTE
        MENUITEM "Paste &Shortcut",             IDM_EDIT_PASTESHORTCUT
        MENUITEM "Вставити &Жорстке Посилання",            IDM_EDIT_PASTEHARDLINK
        MENUITEM "Paste S&ymbolic Link",        IDM_EDIT_PASTE_SYMBOLIC_LINK
