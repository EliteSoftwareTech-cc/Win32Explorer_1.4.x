        MENUITEM "Increase text size",          IDM_VIEW_INCREASE_TEXT_SIZE
        MENUITEM SEPARATOR
        MENUITEM "Placeholder",                 IDM_VIEW_PLACEHOLDER
        MENUITEM SEPARATOR
        MENUITEM "&Autorozmieszczanie",               IDM_VIEW_AUTOARRANGE
        MENUITEM SEPARATOR
        MENUITEM "&Sortuj według",                    IDM_VIEW_SORTBY
        MENUITEM "&Grupuj według",                   IDM_VIEW_GROUPBY
        MENUITEM "Show H&idden Files",          IDM_VIEW_SHOWHIDDENFILES
        MENUITEM "&Refresh",                    IDM_VIEW_REFRESH
        MENUITEM "W&ybierz kolumny...",          IDM_VIEW_SELECTCOLUMNS
        MENUITEM "&Automatyczny rozmiar kolumn",           IDM_VIEW_AUTOSIZECOLUMNS
        MENUITEM "Zapisz układ kolumn jako domyślny", IDM_VIEW_SAVECOLUMNLAYOUTASDEFAULT
        MENUITEM "Zmień &kolory okna szczegółów...", IDM_VIEW_CHANGEDISPLAYCOLOURS
