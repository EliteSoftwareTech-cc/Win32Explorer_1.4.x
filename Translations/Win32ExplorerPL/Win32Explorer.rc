BEGIN
    POPUP "P&lik"
    BEGIN
        MENUITEM "&New Tab",                    IDM_FILE_NEWTAB
        MENUITEM "&Close Tab",                  IDM_FILE_CLOSETAB
        MENUITEM "New W&indow",                 IDM_FILE_NEW_WINDOW
        MENUITEM "Otwó&rz ponownie ostatnią kartę",          IDM_FILE_REOPEN_RECENT_TAB
        MENUITEM "Kl&onuj okno",               IDM_FILE_CLONEWINDOW
        MENUITEM SEPARATOR
