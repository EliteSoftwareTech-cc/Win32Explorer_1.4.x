IDR_MAINMENU MENU
BEGIN
    POPUP "&Archivo"
    BEGIN
        MENUITEM "&New Tab",                    IDM_FILE_NEWTAB
        MENUITEM "&Close Tab",                  IDM_FILE_CLOSETAB
        MENUITEM "New W&indow",                 IDM_FILE_NEW_WINDOW
        MENUITEM "&Reabrir pestaña reciente",          IDM_FILE_REOPEN_RECENT_TAB
        MENUITEM "Cl&onar ventana",               IDM_FILE_CLONEWINDOW
        MENUITEM SEPARATOR
        MENUITEM "&Guardar listado de directorio (en txt)...",  IDM_FILE_SAVEDIRECTORYLISTING
        MENUITEM "&Abrir línea de comandos",        IDM_FILE_OPENCOMMANDPROMPT
        MENUITEM "Abra el símbolo del sistema como &Administrador", IDM_FILE_OPENCOMMANDPROMPTADMINISTRATOR
        MENUITEM "Copy &Folder Path",           IDM_FILE_COPYFOLDERPATH
        MENUITEM "Copiar la &ruta del archivo",            IDM_FILE_COPYITEMPATH
        MENUITEM "Copiar la r&uta universal del archivo",  IDM_FILE_COPYUNIVERSALFILEPATHS
        MENUITEM "Copiar &texto de las columnas",           IDM_FILE_COPYCOLUMNTEXT
        MENUITEM SEPARATOR
        MENUITEM "Cambiar &atributos de archivo...",     IDM_FILE_SETFILEATTRIBUTES
        MENUITEM "&Borrar",                     IDM_FILE_DELETE
        MENUITEM "Delete &Permanently",         IDM_FILE_DELETEPERMANENTLY
        MENUITEM "Rena&me",                     IDM_FILE_RENAME
        MENUITEM "P&roperties",                 IDM_FILE_PROPERTIES
        MENUITEM SEPARATOR
        MENUITEM "&Salir",                       IDM_FILE_EXIT
    END
