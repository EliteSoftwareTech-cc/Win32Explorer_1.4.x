        MENUITEM SEPARATOR
        MENUITEM "&Dividir archivo...",              IDM_ACTIONS_SPLITFILE
        MENUITEM "&Unir archivo...",             IDM_ACTIONS_MERGEFILES
        MENUITEM "&Eliminar archivo...",         IDM_ACTIONS_DESTROYFILES
