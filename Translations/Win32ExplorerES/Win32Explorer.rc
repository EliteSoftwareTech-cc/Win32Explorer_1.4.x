        MENUITEM "&Barra de estado",                 IDM_VIEW_STATUSBAR
        MENUITEM "&Carpetas",                    IDM_VIEW_FOLDERS
        MENUITEM "&Ventana de visualización",             IDM_VIEW_DISPLAYWINDOW
        POPUP "Barra de &herramientas"
        BEGIN
