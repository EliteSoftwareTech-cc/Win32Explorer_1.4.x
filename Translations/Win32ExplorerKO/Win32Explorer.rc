        MENUITEM "닫힌 탭 다시 열기(&R)",          IDM_FILE_REOPEN_RECENT_TAB
        MENUITEM "작업창 복제(&W)",               IDM_FILE_CLONEWINDOW
        MENUITEM SEPARATOR
        MENUITEM "&폴더 목록 저장하기...",  IDM_FILE_SAVEDIRECTORYLISTING
