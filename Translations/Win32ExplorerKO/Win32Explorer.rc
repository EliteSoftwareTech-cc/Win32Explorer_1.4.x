        MENUITEM "Increase text size",          IDM_VIEW_INCREASE_TEXT_SIZE
        MENUITEM SEPARATOR
        MENUITEM "Placeholder",                 IDM_VIEW_PLACEHOLDER
        MENUITEM SEPARATOR
        MENUITEM "자동 정렬(&A)",               IDM_VIEW_AUTOARRANGE
        MENUITEM SEPARATOR
        MENUITEM "정렬(&O)",                    IDM_VIEW_SORTBY
        MENUITEM "분류 방법(&G)",                   IDM_VIEW_GROUPBY
        MENUITEM "Show H&idden Files",          IDM_VIEW_SHOWHIDDENFILES
        MENUITEM "새로 고침(&R)",                    IDM_VIEW_REFRESH
        MENUITEM "열 선택(&C)...",          IDM_VIEW_SELECTCOLUMNS
        MENUITEM "열 너비 자동(&S)",           IDM_VIEW_AUTOSIZECOLUMNS
