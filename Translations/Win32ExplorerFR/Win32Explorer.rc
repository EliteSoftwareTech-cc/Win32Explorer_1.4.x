        MENUITEM "Copier le chemin du fichier",            IDM_FILE_COPYITEMPATH
        MENUITEM "Copier le chemin universel du fichier",  IDM_FILE_COPYUNIVERSALFILEPATHS
        MENUITEM "Copier le &texte de la colonne",           IDM_FILE_COPYCOLUMNTEXT
        MENUITEM SEPARATOR
