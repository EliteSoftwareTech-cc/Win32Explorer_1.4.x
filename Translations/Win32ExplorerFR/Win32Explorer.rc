        MENUITEM "Supprimer [&d]",                     IDM_FILE_DELETE
        MENUITEM "Supprimer définitivement",         IDM_FILE_DELETEPERMANENTLY
        MENUITEM "Reno&mmer",                     IDM_FILE_RENAME
        MENUITEM "P&ropriétés",                 IDM_FILE_PROPERTIES
        MENUITEM SEPARATOR
        MENUITEM "Quitt&er",                       IDM_FILE_EXIT
    END
    POPUP "&Éditer"
    BEGIN
