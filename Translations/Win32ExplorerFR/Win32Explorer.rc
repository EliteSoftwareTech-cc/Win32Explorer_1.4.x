        BEGIN
            MENUITEM "Barre d'&adresse",                IDM_VIEW_TOOLBARS_ADDRESS_BAR
            MENUITEM "Barre d'outils principale",               IDM_VIEW_TOOLBARS_MAIN_TOOLBAR
            MENUITEM "Marque-pages",                  IDM_VIEW_TOOLBARS_BOOKMARKS_TOOLBAR
            MENUITEM "Lecteurs",                     IDM_VIEW_TOOLBARS_DRIVES_TOOLBAR
            MENUITEM "Barre d'outils applications",        IDM_VIEW_TOOLBARS_APPLICATION_TOOLBAR
            MENUITEM SEPARATOR
            MENUITEM "Verrouiller les barres d'outils",              IDM_VIEW_TOOLBARS_LOCK_TOOLBARS
            MENUITEM "Personnaliser...",               IDM_VIEW_TOOLBARS_CUSTOMIZE
        END
        MENUITEM SEPARATOR
        MENUITEM "Diminuer la taille du texte",          IDM_VIEW_DECREASE_TEXT_SIZE
        MENUITEM "Augmenter la taille du texte",          IDM_VIEW_INCREASE_TEXT_SIZE
        MENUITEM SEPARATOR
        MENUITEM "Placeholder",                 IDM_VIEW_PLACEHOLDER
        MENUITEM SEPARATOR
        MENUITEM "&Arrangement automatique",               IDM_VIEW_AUTOARRANGE
        MENUITEM SEPARATOR
        MENUITEM "Trier par",                    IDM_VIEW_SORTBY
        MENUITEM "Grouper par",                   IDM_VIEW_GROUPBY
        MENUITEM "Afficher les fich&iers cachés",          IDM_VIEW_SHOWHIDDENFILES
        MENUITEM "Actualise&r",                    IDM_VIEW_REFRESH
        MENUITEM "Sélectionner les &colonnes...",          IDM_VIEW_SELECTCOLUMNS
        MENUITEM "Largeur automatique",           IDM_VIEW_AUTOSIZECOLUMNS
        MENUITEM "Enregistrer comme format de colonnes par défaut", IDM_VIEW_SAVECOLUMNLAYOUTASDEFAULT
        MENUITEM "Modifier les c&ouleurs de la fenêtre d'affichage...", IDM_VIEW_CHANGEDISPLAYCOLOURS
        MENUITEM SEPARATOR
        POPUP "&Filtre"
        BEGIN
            MENUITEM "Définir un filtre...",              IDM_FILTER_FILTERRESULTS
            MENUITEM "Activer le filtr&e",              IDM_FILTER_ENABLE_FILTER
        END
    END
    POPUP "Actions"
    BEGIN
        MENUITEM "Nouveau dossier [&f]",                 IDM_ACTIONS_NEWFOLDER
        MENUITEM SEPARATOR
        MENUITEM "Découpage de fichier...",              IDM_ACTIONS_SPLITFILE
        MENUITEM "Fusion de fichiers...",             IDM_ACTIONS_MERGEFILES
        MENUITEM "Suppression de fichier(s)...",         IDM_ACTIONS_DESTROYFILES
    END
    POPUP "Aller à"
    BEGIN
