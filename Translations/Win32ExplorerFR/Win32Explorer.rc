        MENUITEM "Suivant",                    IDM_GO_FORWARD
        MENUITEM "Monter",                         IDM_GO_UP
        MENUITEM SEPARATOR
        MENUITEM "&Historique",                    IDM_GO_HISTORY
        MENUITEM "Emplacements &fréquents",         IDM_GO_FREQUENT_LOCATIONS
    END
    MENUITEM "Marque-pages",                  IDM_BOOKMARKS
    POPUP "Outils"
    BEGIN
        MENUITEM "Chercher...",                  IDM_TOOLS_SEARCH
        MENUITEM "Personnaliser les couleurs...",        IDM_TOOLS_CUSTOMIZECOLORS
        MENUITEM SEPARATOR
        MENUITEM "Exécuter le script...",               IDM_TOOLS_RUNSCRIPT
        MENUITEM "&Options...",                 IDM_TOOLS_OPTIONS
    END
    POPUP "Fenêtre"
    BEGIN
        MENUITEM "Rechercher les onglet&s...",             IDM_WINDOW_SEARCH_TABS
    END
    POPUP "Aide"
    BEGIN
        MENUITEM "D&ocumentation en ligne",       IDM_HELP_ONLINE_DOCUMENTATION
        MENUITEM SEPARATOR
        MENUITEM "Vérifier les mises à jour...",        IDM_HELP_CHECKFORUPDATES
        MENUITEM "&À propos de Win32Explorer",           IDM_HELP_ABOUT
    END
END

