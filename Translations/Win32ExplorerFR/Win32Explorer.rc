IDR_MAINMENU MENU
BEGIN
    POPUP "&Fichier"
    BEGIN
        MENUITEM "&Nouvel onglet",                    IDM_FILE_NEWTAB
        MENUITEM "Fermer l'onglet",                  IDM_FILE_CLOSETAB
        MENUITEM "Nouvelle fenêtre",                 IDM_FILE_NEW_WINDOW
        MENUITEM "&Réouvrir l'onglet récent",          IDM_FILE_REOPEN_RECENT_TAB
        MENUITEM "Fermer la fenêtre",               IDM_FILE_CLONEWINDOW
        MENUITEM SEPARATOR
        MENUITEM "Sauvegarder la &liste des dossiers...",  IDM_FILE_SAVEDIRECTORYLISTING
        MENUITEM "&Ouvrir une invite de commande",        IDM_FILE_OPENCOMMANDPROMPT
        MENUITEM "Ouvrir l’invite de commande en tant qu'&Administrateur", IDM_FILE_OPENCOMMANDPROMPTADMINISTRATOR
