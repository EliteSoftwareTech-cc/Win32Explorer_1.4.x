        MENUITEM "&Désélectionner un caractère générique",       IDM_EDIT_WILDCARDDESELECT
    END
    POPUP "Affichage"
    BEGIN
        MENUITEM "Do&uble panneau",                  IDM_VIEW_DUAL_PANE
        MENUITEM "&Barre d'état",                 IDM_VIEW_STATUSBAR
        MENUITEM "Dossiers",                    IDM_VIEW_FOLDERS
        MENUITEM "Fenêtre d'affichage",             IDM_VIEW_DISPLAYWINDOW
